generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    ADMIN
    KOORDINATOR
    ANGGOTA
}

enum ScheduleType {
    DAILY
    WEEKLY
    MONTHLY
    CUSTOM
}

enum ProgramRequirementType {
    PHOTO
    DOCUMENT
}

enum SessionStatus {
    DRAFT
    COMPLETED
    COMPLETED_WITH_ISSUE
    NOT_EXECUTED
}

model User {
    id                String             @id @default(cuid())
    name              String
    username          String             @unique
    password          String
    role              Role               @default(ANGGOTA)
    telegramId        String?            @unique
    divisionId        String?
    division          Division?          @relation(fields: [divisionId], references: [id])
    sessions          Session[]
    pushSubscriptions PushSubscription[]
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt

    @@index([divisionId])
    @@index([role])
}

model Division {
    id          String     @id @default(cuid())
    name        String     @unique
    description String?
    phoneNumber String?
    users       User[]
    programs    Program[]
    deadlines   Deadline[]
    createdAt   DateTime   @default(now())
    updatedAt   DateTime   @updatedAt
}

model Deadline {
    id             String    @id @default(cuid())
    title          String
    description    String?
    dueDate        DateTime  @db.Date
    divisionId     String?
    division       Division? @relation(fields: [divisionId], references: [id], onDelete: SetNull)
    customDivision String?
    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt

    @@index([dueDate])
    @@index([divisionId])
}

model Program {
    id                String                 @id @default(cuid())
    name              String
    description       String?
    scheduleType      ScheduleType
    scheduleDays      Int[] //  1=M0=Sunday,onday, etc. (for DAILY/WEEKLY)
    scheduleMonthDays Int[] // 1-31 (for MONTHLY - which day of month)
    customDates       DateTime[] // Specific dates (for CUSTOM)
    scheduleTime      String? // Format: "HH:mm"
    requirementType   ProgramRequirementType @default(PHOTO)
    minUploads        Int                    @default(1)
    isActive          Boolean                @default(true)
    divisionId        String
    division          Division               @relation(fields: [divisionId], references: [id], onDelete: Cascade)
    schedules         ScheduleInstance[]
    createdAt         DateTime               @default(now())
    updatedAt         DateTime               @updatedAt

    @@index([divisionId])
    @@index([isActive])
}

model ScheduleInstance {
    id        String    @id @default(cuid())
    date      DateTime  @db.Date
    programId String
    program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
    sessions  Session[]
    createdAt DateTime  @default(now())

    @@unique([programId, date])
    @@index([date])
}

model Session {
    id            String           @id @default(cuid())
    status        SessionStatus    @default(DRAFT)
    startedAt     DateTime         @default(now())
    submittedAt   DateTime?
    issueNote     String?
    userId        String
    user          User             @relation(fields: [userId], references: [id])
    scheduleId    String
    schedule      ScheduleInstance @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
    photos        Photo[]
    documents     Document[]
    isAutoCreated Boolean          @default(false)
    createdAt     DateTime         @default(now())
    updatedAt     DateTime         @updatedAt

    @@unique([scheduleId])
    @@index([userId])
    @@index([status])
}

model Photo {
    id          String   @id @default(cuid())
    url         String
    caption     String?
    storagePath String
    sessionId   String
    session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
    createdAt   DateTime @default(now())

    @@index([sessionId])
}

model Document {
    id          String   @id @default(cuid())
    url         String
    filename    String
    storagePath String
    sessionId   String
    session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
    createdAt   DateTime @default(now())

    @@index([sessionId])
}

model PushSubscription {
    id             String    @id @default(cuid())
    endpoint       String    @unique
    p256dh         String
    authKey        String
    expirationTime DateTime?
    userId         String?
    user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt

    @@index([userId])
}

model Quarter {
    id        String   @id @default(cuid())
    name      String   @unique
    active    Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    agendas Agenda[]

    @@index([name])
}

model Agenda {
    id                String   @id @default(cuid())
    name              String
    personResponsible String
    date              String
    completed         Boolean? @default(false)
    quarterId         String
    quarter           Quarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
}
